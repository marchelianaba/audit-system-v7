# ===== Anthropic =====
ANTHROPIC_API_KEY=sk-ant-...

# ===== Database =====
# Dev lokal (docker-compose):
DATABASE_URL=postgresql+asyncpg://audit:audit@localhost:5432/audit_v7
# Production (Fly Postgres):
# DATABASE_URL=postgresql+asyncpg://...flycast/...

# ===== App =====
APP_ENV=development
APP_SECRET_KEY=ganti-dengan-secret-acak-32-karakter
APP_DATA_DIR=/data
APP_V6_PATH=/v6
APP_WIKI_PATH=/wiki
# Vault pengetahuan penuh (Obsidian/Karpathy), read-only. Catatan di <path>/wiki/.
# Kosongkan untuk menonaktifkan fitur baca vault.
APP_VAULT_PATH=
APP_CORS_ORIGINS=http://localhost:3000,https://audit-ai-v7.vercel.app

# ===== CACM / EWS SIRUP (integrasi agent tim — C1b) =====
# Kosongkan untuk nonaktifkan integrasi live (ingest offline tetap jalan).
CACM_WEBHOOK_SECRET=
CACM_AGENT_BASE_URL=
CACM_AGENT_API_KEY=
# Otomasi C2: dari sinyal live (webhook/pull) auto-buat usulan penugasan.
# off | merah (default) | merah_kuning
CACM_AUTO_PROMOTE=merah

# ===== Frontend =====
NEXT_PUBLIC_API_BASE=http://localhost:8000
